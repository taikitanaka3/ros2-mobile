{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/battery.schema.json",
  "title": "AndroidBatteryPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp_ms",
    "frame_id",
    "percentage",
    "voltage_v",
    "current_a",
    "status"
  ],
  "properties": {
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 253402300799000
    },
    "frame_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_./-]{0,127}$"
    },
    "timestamp_offset_ms": {
      "type": "integer",
      "minimum": -600000,
      "maximum": 600000
    },
    "qos_profile": {
      "type": "string",
      "enum": [
        "best_effort",
        "reliable"
      ]
    },
    "queue_depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "voltage_v": {
      "type": "number",
      "minimum": 0
    },
    "current_a": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "unknown",
        "charging",
        "discharging",
        "not_charging",
        "full"
      ]
    }
  }
}

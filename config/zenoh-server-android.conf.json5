{
  mode: "router",

  listen: {
    endpoints: [
      "tcp/0.0.0.0:7447",
    ],
  },

  scouting: {
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto",
      listen: true,

# ROS2Mobile — environment variables
# Copy this file to .env and adjust for your setup.
#
#   cp .env.example .env

# ── Zenoh router ──────────────────────────────────────────────────────────────

# Port the Zenoh router listens on inside the container and exposes on the host.
# Android devices must be configured to connect to <host-ip>:ZENOH_PORT.
ZENOH_PORT=7447
ZENOH_PORT_HOST=7447

# Zenoh router image (pin a version for reproducibility).
ZENOH_IMAGE=eclipse/zenoh:1.3.3

# Log verbosity for the Zenoh router: error | warn | info | debug | trace
ZENOH_LOG_LEVEL=info

# ── Bridge node ───────────────────────────────────────────────────────────────

# Logical name for the Android device.  Used to build Zenoh keys and ROS topics.
# Example: if DEVICE_ID=pixel7, the IMU topic becomes /android/pixel7/imu
DEVICE_ID=device1

# Bridge image.  python:3.12-slim installs deps at startup from bridge/requirements.txt.
BRIDGE_IMAGE=python:3.12-slim

# Additional sensor bindings beyond the default IMU one added by docker-compose.yml.
# Format (space-separated): STREAM:ZENOH_KEY:ROS_TOPIC
# Supported streams: imu, gps, battery, camera, magnetometer, barometer, joy
#
# Example — enable GPS and battery in addition to IMU:
# BRIDGE_BINDINGS=--binding imu:android/device1/imu:/android/device1/imu --binding gps:android/device1/gps:/android/device1/gps --binding battery:android/device1/battery:/android/device1/battery
BRIDGE_BINDINGS=
